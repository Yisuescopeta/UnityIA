{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    { "$ref": "../common/mutation-command.schema.json" },
    {
      "properties": {
        "command": { "const": "scene.save" },
        "arguments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenePath"],
          "properties": {
            "scenePath": { "type": "string", "pattern": "^Assets/.+\\.unity$" }
          }
        }
      }
    }
  ]
}

