{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    { "$ref": "../common/command-base.schema.json" },
    {
      "properties": {
        "command": { "const": "validation.command.validate" },
        "arguments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["envelope"],
          "properties": {
            "envelope": { "$ref": "../common/command-base.schema.json" }
          }
        }
      }
    }
  ]
}

