{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    { "$ref": "../common/command-base.schema.json" },
    {
      "properties": {
        "command": { "const": "context.snapshot" },
        "arguments": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "includeHierarchy": { "type": "boolean" }
          }
        }
      }
    }
  ]
}
