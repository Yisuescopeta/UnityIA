{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    { "$ref": "../common/mutation-command.schema.json" },
    {
      "properties": {
        "command": { "const": "scene.object.delete" },
        "arguments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target"],
          "properties": {
            "target": { "$ref": "../common/object-reference.schema.json" }
          }
        }
      }
    }
  ]
}

