{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    { "$ref": "../common/mutation-command.schema.json" },
    {
      "properties": {
        "command": { "const": "scene.object.create-empty" },
        "arguments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1, "maxLength": 200 },
            "parent": {
              "oneOf": [
                { "$ref": "../common/object-reference.schema.json" },
                { "type": "null" }
              ]
            },
            "position": { "$ref": "../common/vector3.schema.json" },
            "rotationEuler": { "$ref": "../common/vector3.schema.json" },
            "scale": { "$ref": "../common/vector3.schema.json" }
          }
        }
      }
    }
  ]
}

