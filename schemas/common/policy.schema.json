{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://unityia.dev/schemas/common/policy.schema.json",
  "title": "UnityIA project policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "authorizationMode", "allow", "paths"],
  "properties": {
    "version": { "const": "0.1" },
    "authorizationMode": { "enum": ["confirm_actions"] },
    "allow": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "context.read",
          "capabilities.read",
          "scene.gameobject.create",
          "scene.component.add",
          "scene.component.write",
          "scene.save",
          "validation.scene.run",
          "tests.run",
          "scene.modify",
          "prefab.modify"
        ]
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["read", "write"],
      "properties": {
        "read": {
          "type": "array",
          "items": { "type": "string", "pattern": "^Assets/" }
        },
        "write": {
          "type": "array",
          "items": { "type": "string", "pattern": "^Assets/" }
        }
      }
    }
  }
}
