{
  "version": "0.1",
  "authorizationMode": "confirm_actions",
  "allow": [
    "context.read",
    "capabilities.read",
    "scene.gameobject.create",
    "scene.component.add",
    "scene.component.write",
    "scene.save",
    "validation.scene.run"
  ],
  "paths": {
    "read": [
      "Assets/**"
    ],
    "write": [
      "Assets/Scenes/**"
    ]
  }
}
